# PostgreSQL (Railway injecte DATABASE_URL automatiquement si PostgreSQL est lié au service)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key_here

# Cookie de session Vinted FR
# Récupérer depuis DevTools → Network → n'importe quelle requête vinted.fr → en-tête Cookie
# À renouveler manuellement tous les ~30 jours
VINTED_SESSION_COOKIE=_vinted_fr_session=xxxxxxxxxxxx

# Optionnel : chemin des navigateurs Playwright sur Railway
# PLAYWRIGHT_BROWSERS_PATH=/app/.playwright-browsers
